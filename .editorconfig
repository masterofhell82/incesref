# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true


# 4 space indentation
[*.{tsx,ts,js,jsx,html,py,css,yml,md}]
charset = utf-8
indent_style = space
indent_size = 4
tab_width = 4

[{package.json, composer.json}]
indent_style = space
indent_size = 4
tab_width = 4
